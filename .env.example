# Oura personal access tokens — one per person.
# Generate at: https://cloud.ouraring.com/personal-access-tokens
#
# Pattern: OURA_TOKEN_<PERSON> where <PERSON> is any label you choose (e.g. KARTIK, PARTNER).
# The check-auth script discovers all variables matching this prefix.

OURA_TOKEN_KARTIK=your_token_here
# OURA_TOKEN_PARTNER=partner_token_here
