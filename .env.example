# Oura personal access tokens — one per person.
# Generate at: https://cloud.ouraring.com/personal-access-tokens
#
# Pattern: OURA_TOKEN_<PERSON> where <PERSON> is any label you choose (e.g. KARTIK, PARTNER).
# The check-auth script discovers all variables matching this prefix.

OURA_TOKEN_KARTIK=your_token_here
# OURA_TOKEN_PARTNER=partner_token_here

# ── Phase 9: Dashboard + Chat ─────────────────────────────────────────────────

# Anthropic API key — required for the chat interface (F9.4).
# Get one at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Command to start the Oura MCP server (F3.x).  The chat backend proxies tool
# calls to this process over stdio. Leave unset until Phase 3 is complete.
# OURA_MCP_CMD=uv run python -m oura_fun.mcp_server
